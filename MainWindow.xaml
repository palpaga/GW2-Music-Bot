<Window x:Class="Gw2MusicBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GW2 Music Bot - API Edition" Height="700" Width="550" Topmost="True" WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Guild Wars 2 Music Bot" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Name="TxtSearch" Grid.Column="0" VerticalContentAlignment="Center" Padding="5" Text="Zelda"/>
            <Button Name="BtnSearch" Grid.Column="1" Content="Search" Padding="15,5" Margin="5,0,0,0" Click="BtnSearch_Click"/>
            <Button Name="BtnShowFavorites" Grid.Column="2" Content="★ Favorites" Padding="15,5" Margin="5,0,0,0" Click="BtnShowFavorites_Click"/>
            <Button Name="BtnLoadLocal" Grid.Column="3" Content="Local..." Padding="10,5" Margin="5,0,0,0" Click="BtnLoad_Click"/>
        </Grid>

        <Border Grid.Row="2" BorderBrush="LightGray" BorderThickness="1" Margin="0,0,0,10">
            <ListBox Name="LstResults" SelectionChanged="LstResults_SelectionChanged" ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="5" Width="500">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" MaxWidth="300"/>
                                <TextBlock Text=" - Score: " Foreground="Gray" Margin="5,0,0,0"/>
                                <TextBlock Text="{Binding Score}" Foreground="DarkGreen" FontWeight="Bold"/>
                            </StackPanel>
                            
                            <Button Grid.Column="1" Content="▶ Preview" Width="60" Margin="5,0" Click="BtnPreviewListen_Click" Tag="{Binding}"/>
                            <Button Grid.Column="2" Content="★" Width="30" Click="BtnToggleFavorite_Click" Tag="{Binding}"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <GroupBox Grid.Row="3" Header="Player Settings" Margin="0,0,0,10" Padding="5">
            <StackPanel>
                <StackPanel Margin="0,5,0,0">
                    <CheckBox Name="ChkDisableFKeys" Content="Disable Sharp/Flat notes (Ignore F1-F5)" FontWeight="SemiBold" Checked="ChkDisableFKeys_Changed" Unchecked="ChkDisableFKeys_Changed" Margin="0,5,0,0"/>
                    <TextBlock Text="Checked by default. Function keys are only available on the Piano. Other instruments cannot play these notes." FontSize="10" Foreground="Gray" Margin="20,0,0,10" TextWrapping="Wrap"/>
                    
                    <CheckBox Name="ChkTwoOctaves" Content="Restrict to 2 Octaves (Faster playback)" FontWeight="SemiBold" Checked="ChkTwoOctaves_Changed" Unchecked="ChkTwoOctaves_Changed"/>
                    <TextBlock Text="Reduces octave switching. Helps prevent the game from dropping notes and desyncing into chord modes on very fast songs." FontSize="10" Foreground="Gray" Margin="20,0,0,5" TextWrapping="Wrap"/>
                </StackPanel>

                <Grid Margin="0,10,0,5">
                    <TextBlock Text="Playback Speed:" HorizontalAlignment="Left" />
                    <TextBlock Name="TxtSpeedVal" Text="1.00x" HorizontalAlignment="Right" FontWeight="Bold" />
                </Grid>
                <Slider Name="SliderSpeed" Minimum="0.1" Maximum="2.0" Value="1.0" TickFrequency="0.1" IsSnapToTickEnabled="True" ValueChanged="SliderSpeed_ValueChanged"/>
                
                <Expander Header="Advanced Settings &amp; Key Mapping" Margin="0,10,0,0">
                    <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="3" Padding="5" Background="#F9F9F9">
                        <StackPanel>
                            <Grid Margin="5,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Delay before an octave change (ms) :" VerticalAlignment="Center"/>
                                <TextBox Name="TxtOctaveDelay" Grid.Column="1" Width="40" TextAlignment="Right" VerticalContentAlignment="Center" Margin="5,0"/>
                                <Button Name="BtnSaveDelay" Grid.Column="2" Content="Save" Padding="10,2" Click="BtnSaveDelay_Click"/>
                            </Grid>
                            
                            <TextBlock Text="Increase this delay if your instrument keeps getting stuck into 'Chord mode'." FontSize="10" Foreground="Gray" Margin="5,-5,0,10" TextWrapping="Wrap"/>
                            <Separator Margin="0,0,0,10"/>
                            
                            <Grid Margin="0,0,0,5">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Top Row (Sharp / Flat Notes = Function keys) -->
                                <StackPanel Grid.Row="0" Grid.Column="0" HorizontalAlignment="Right" Margin="0,0,-15,2" Panel.ZIndex="1">
                                    <TextBlock Text="Do#" Foreground="DarkSlateGray" TextAlignment="Center" FontSize="10"/>
                                    <TextBox Name="TxtNote1" Width="30" PreviewKeyDown="KeyBind_KeyDown" Tag="Note_1" IsReadOnly="True" TextAlignment="Center" Padding="2" Background="#EEE"/>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right" Margin="0,0,-15,2" Panel.ZIndex="1">
                                    <TextBlock Text="Ré#" Foreground="DarkSlateGray" TextAlignment="Center" FontSize="10"/>
                                    <TextBox Name="TxtNote3" Width="30" PreviewKeyDown="KeyBind_KeyDown" Tag="Note_3" IsReadOnly="True" TextAlignment="Center" Padding="2" Background="#EEE"/>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="3" HorizontalAlignment="Right" Margin="0,0,-15,2" Panel.ZIndex="1">
                                    <TextBlock Text="Fa#" Foreground="DarkSlateGray" TextAlignment="Center" FontSize="10"/>
                                    <TextBox Name="TxtNote6" Width="30" PreviewKeyDown="KeyBind_KeyDown" Tag="Note_6" IsReadOnly="True" TextAlignment="Center" Padding="2" Background="#EEE"/>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="4" HorizontalAlignment="Right" Margin="0,0,-15,2" Panel.ZIndex="1">
                                    <TextBlock Text="Sol#" Foreground="DarkSlateGray" TextAlignment="Center" FontSize="10"/>
                                    <TextBox Name="TxtNote8" Width="30" PreviewKeyDown="KeyBind_KeyDown" Tag="Note_8" IsReadOnly="True" TextAlignment="Center" Padding="2" Background="#EEE"/>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="5" HorizontalAlignment="Right" Margin="0,0,-15,2" Panel.ZIndex="1">
                                    <TextBlock Text="La#" Foreground="DarkSlateGray" TextAlignment="Center" FontSize="10"/>
                                    <TextBox Name="TxtNote10" Width="30" PreviewKeyDown="KeyBind_KeyDown" Tag="Note_10" IsReadOnly="True" TextAlignment="Center" Padding="2" Background="#EEE"/>
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="6" HorizontalAlignment="Right" Margin="0,0,-15,2" Panel.ZIndex="1">
                                    <TextBlock Text="Oct -" Foreground="DarkBlue" TextAlignment="Center" FontSize="10"/>
                                    <TextBox Name="TxtOctDown" Width="30" PreviewKeyDown="KeyBind_KeyDown" Tag="OctaveDown" IsReadOnly="True" TextAlignment="Center" Padding="2" Background="#EEE"/>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="7" HorizontalAlignment="Right" Margin="0,0,-15,2" Panel.ZIndex="1">
                                    <TextBlock Text="Oct +" Foreground="DarkBlue" TextAlignment="Center" FontSize="10"/>
                                    <TextBox Name="TxtOctUp" Width="30" PreviewKeyDown="KeyBind_KeyDown" Tag="OctaveUp" IsReadOnly="True" TextAlignment="Center" Padding="2" Background="#EEE"/>
                                </StackPanel>

                                <!-- Bottom Row (Natural Notes & Controls) -->
                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="2">
                                    <TextBlock Text="Do" TextAlignment="Center" FontWeight="SemiBold"/>
                                    <TextBox Name="TxtNote0" Width="30" PreviewKeyDown="KeyBind_KeyDown" Tag="Note_0" IsReadOnly="True" TextAlignment="Center" Padding="2"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="2">
                                    <TextBlock Text="Ré" TextAlignment="Center" FontWeight="SemiBold"/>
                                    <TextBox Name="TxtNote2" Width="30" PreviewKeyDown="KeyBind_KeyDown" Tag="Note_2" IsReadOnly="True" TextAlignment="Center" Padding="2"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="2" Margin="2">
                                    <TextBlock Text="Mi" TextAlignment="Center" FontWeight="SemiBold"/>
                                    <TextBox Name="TxtNote4" Width="30" PreviewKeyDown="KeyBind_KeyDown" Tag="Note_4" IsReadOnly="True" TextAlignment="Center" Padding="2"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="3" Margin="2">
                                    <TextBlock Text="Fa" TextAlignment="Center" FontWeight="SemiBold"/>
                                    <TextBox Name="TxtNote5" Width="30" PreviewKeyDown="KeyBind_KeyDown" Tag="Note_5" IsReadOnly="True" TextAlignment="Center" Padding="2"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="4" Margin="2">
                                    <TextBlock Text="Sol" TextAlignment="Center" FontWeight="SemiBold"/>
                                    <TextBox Name="TxtNote7" Width="30" PreviewKeyDown="KeyBind_KeyDown" Tag="Note_7" IsReadOnly="True" TextAlignment="Center" Padding="2"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="5" Margin="2">
                                    <TextBlock Text="La" TextAlignment="Center" FontWeight="SemiBold"/>
                                    <TextBox Name="TxtNote9" Width="30" PreviewKeyDown="KeyBind_KeyDown" Tag="Note_9" IsReadOnly="True" TextAlignment="Center" Padding="2"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="6" Margin="2">
                                    <TextBlock Text="Si" TextAlignment="Center" FontWeight="SemiBold"/>
                                    <TextBox Name="TxtNote11" Width="30" PreviewKeyDown="KeyBind_KeyDown" Tag="Note_11" IsReadOnly="True" TextAlignment="Center" Padding="2"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="7" Margin="2">
                                    <TextBlock Text="Do2" TextAlignment="Center" FontWeight="SemiBold"/>
                                    <TextBox Name="TxtHighC" Width="30" PreviewKeyDown="KeyBind_KeyDown" Tag="HighC" IsReadOnly="True" TextAlignment="Center" Padding="2"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="8" Margin="2" Grid.ColumnSpan="2">
                                    <TextBlock Text="Stop" TextAlignment="Center" FontWeight="SemiBold" Foreground="DarkRed"/>
                                    <TextBox Name="TxtStop" Width="60" PreviewKeyDown="KeyBind_KeyDown" Tag="Stop" IsReadOnly="True" TextAlignment="Center" Padding="2" Foreground="DarkRed"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Expander>
            </StackPanel>
        </GroupBox>

        <StackPanel Grid.Row="4">
            <TextBlock Name="TxtFileName" Text="No music selected" FontStyle="Italic" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            
            <Grid Margin="0,0,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Name="BtnPlay" Grid.Column="0" Content="PLAY" Padding="10" Click="BtnPlay_Click" IsEnabled="False" Background="#FF4CAF50" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,5,0"/>
                <Button Name="BtnStop" Grid.Column="1" Content="Stop" Padding="10,0" Width="80" Click="BtnStop_Click" IsEnabled="False"/>
            </Grid>
            <TextBlock Text="Important: Click on the game window right after pressing Play!" Foreground="DarkRed" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock Margin="0,15,0,0" HorizontalAlignment="Center" FontSize="11" Foreground="Gray">
                Made with ❤️ by Lama and Google Gemini -
                <Hyperlink NavigateUri="https://github.com/palpaga/GW2-Music-Bot" RequestNavigate="Hyperlink_RequestNavigate">
                    https://github.com/palpaga/GW2-Music-Bot
                </Hyperlink>
            </TextBlock>
        </StackPanel>
    </Grid>
</Window>
